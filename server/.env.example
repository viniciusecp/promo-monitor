# Telegram API credentials (obrigatório)
# Obtenha em: https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=seu_api_hash_aqui
TELEGRAM_PHONE=+5511999999999

# Bot para notificações na sua DM (crie no @BotFather e cole o token)
# Sem o token, nenhuma notificação é enviada.
TELEGRAM_BOT_TOKEN=

# App
DEBUG=false
LOG_LEVEL=INFO

# Matching
MATCH_SCORE_THRESHOLD=0.6

# Validação por LLM (LangChain + OpenRouter)
# Sem OPENROUTER_API_KEY a validação fica desativada (só o matcher decide).
# LLM_MODEL aceita qualquer id de modelo do OpenRouter (inclusive variantes :free).
OPENROUTER_API_KEY=
LLM_MODEL=openrouter/free

# API
API_HOST=0.0.0.0
API_PORT=3333

# Database (opcional - default: sqlite:///data/promobot.db)
# DATABASE_URL=sqlite:///data/promobot.db
